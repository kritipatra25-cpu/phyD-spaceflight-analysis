#################################################
# OSD120 Photosynthesis Pathway
#################################################

library(SBGNview)
library(xml2)
library(rsvg)

#################################################
# Render pathway
#################################################

SBGNview(

    input.sbgn = "PWY-101.sbgn",

    output.file = "OSD120_Photosynthesis"

)

#################################################
# Load SVG
#################################################

svg <- read_xml(
    "OSD120_Photosynthesis_PWY-101.sbgn.svg"
)

#################################################
# Color function
#################################################

fc_to_color <- function(fc){

    if(fc >= 1){

        return("#8B0000")

    } else if(fc >= 0.5){

        return("#FF4500")

    } else if(fc > 0){

        return("#FFA07A")

    } else if(fc <= -0.5){

        return("#00008B")

    } else if(fc < 0){

        return("#87CEFA")

    } else {

        return("black")
    }
}

#################################################
# OSD120 Photosynthesis Fold Changes
#################################################

fc_map <- data.frame(

    node = c(

        "PsbA",
        "PsbB",
        "PsbC",
        "PsbD",

        "PsaA",
        "PsaB",
        "PsaC",

        "PetA",
        "PetB",
        "PetC",
        "PetD"

    ),

    fold_change = c(

         1.25,
        -0.22,
        -0.19,
         0.40,

        -0.61,
        -0.44,
        -0.05,

        -0.02,
         0.11,
         0.95,
         0.10
    )
)

#################################################
# Color nodes
#################################################

for(i in 1:nrow(fc_map)){

    current_node <- fc_map$node[i]

    current_fc <- fc_map$fold_change[i]

    current_color <- fc_to_color(current_fc)

    matched_nodes <- xml_find_all(

        svg,

        paste0(
            ".//*[local-name()='text' and contains(.,'",
            current_node,
            "')]"
        )
    )

    cat(
        current_node,
        " -> ",
        length(matched_nodes),
        " matches\n"
    )

    for(j in matched_nodes){

        xml_set_attr(
            j,
            "fill",
            current_color
        )

        xml_set_attr(
            j,
            "font-size",
            "20"
        )

        xml_set_attr(
            j,
            "font-weight",
            "bold"
        )
    }
}

#################################################
# Save SVG
#################################################

write_xml(

    svg,

    "OSD120_Photosynthesis_Colored.svg"
)

#################################################
# Convert PNG
#################################################

rsvg_png(

    "OSD120_Photosynthesis_Colored.svg",

    "OSD120_Photosynthesis_Colored.png",

    width = 6000,

    height = 5000
)

cat(
    "\nOSD120 Photosynthesis pathway rendered successfully.\n"
)
