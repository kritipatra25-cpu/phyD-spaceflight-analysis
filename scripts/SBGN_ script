> fc_map <- data.frame(
+     
+     node = c(
+         
+         "PsbA",
+         "PsbB",
+         "PsbC",
+         "PsbD",
+         
+         "PsaA",
+         "PsaB",
+         "PsaC",
+         
+         "chlorophyll",
+         
+         "photosystem II",
+         "photosystem I"
+         
+     ),
+     
+     fold_change = c(
+         
+         4.2,
+         3.5,
+         3.0,
+         2.8,
+         
+         2.5,
+         2.2,
+         1.8,
+         
+         3.7,
+         
+         4.5,
+         3.2
+         
+     )
+     
+ )
> fc_to_color <- function(fc){
+     
+     if(fc >= 3){
+         
+         return("#B22222")
+         
+     } else if(fc >= 2){
+         
+         return("#FF6347")
+         
+     } else if(fc >= 1){
+         
+         return("#FFA07A")
+         
+     } else if(fc <= -3){
+         
+         return("#00008B")
+         
+     } else if(fc <= -2){
+         
+         return("#4169E1")
+         
+     } else if(fc <= -1){
+         
+         return("#87CEFA")
+         
+     } else {
+         
+         return("white")
+     }
+ }
> for(i in 1:nrow(fc_map)){
+     
+     current_node <- fc_map$node[i]
+     
+     current_fc <- fc_map$fold_change[i]
+     
+     current_color <- fc_to_color(current_fc)
+     
+     matched_nodes <- xml_find_all(
+         
+         svg,
+         
+         paste0(
+             
+             ".//*[local-name()='text' and contains(., '",
+             
+             current_node,
+             
+             "')]"
+             
+         )
+     )
+     
+     for(j in matched_nodes){
+         
+         xml_set_attr(
+             j,
+             "fill",
+             current_color
+         )
+         
+         xml_set_attr(
+             j,
+             "font-weight",
+             "bold"
+         )
+         
+         xml_set_attr(
+             j,
+             "font-size",
+             "18"
+         )
+     }
+ }
> write_xml(
+     
+     svg,
+     
+     "Photosynthesis_Dynamic_FoldChange.svg"
+ )
> rsvg_png(
