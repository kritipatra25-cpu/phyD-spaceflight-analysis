+     "Photosynthesis_Dynamic_FoldChange.svg",
+     
+     "Photosynthesis_Dynamic_FoldChange.png",
+     
+     width = 6000,
+     
+     height = 5000
+ )
> list.files(pattern = "Photosynthesis")


