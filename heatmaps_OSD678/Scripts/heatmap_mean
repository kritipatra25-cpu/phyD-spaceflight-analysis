ros_data$Flight_mean <- rowMeans(
ros_data[, c(
"Flight_Col.0_Light_bio_rep1",
"Flight_Col.0_Light_bio_rep2",
"Flight_Col.0_Light_bio_rep3"
)],
na.rm = TRUE
