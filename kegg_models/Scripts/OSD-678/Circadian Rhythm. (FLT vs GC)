if (!requireNamespace("BiocManager", quietly = TRUE))
  install.packages("BiocManager")

BiocManager::install(c(
  "pathview",
  "org.At.tair.db",
  "KEGGREST",
  "AnnotationDbi"
))

library(pathview)
library(org.At.tair.db)
library(AnnotationDbi)
library(dplyr)
expr <- read.csv(
  "GLDS-612_rna_seq_differential_expression_rRNArm_GLbulkRNAseq.csv"
)

head(expr)
colnames(expr)
ground_cols <- grep(
  "^Ground_control",
  colnames(expr),
  value = TRUE
)

flight_cols <- grep(
  "^Flight",
  colnames(expr),
  value = TRUE
)
expr$Ground_mean <- rowMeans(
  expr[, ground_cols],
  na.rm = TRUE
)

expr$Flight_mean <- rowMeans(
  expr[, flight_cols],
  na.rm = TRUE
)
expr$log2FC <- log2(
  (expr$Flight_mean + 1) /
  (expr$Ground_mean + 1)
)
circadian_genes <- c(

  "AT5G61380",  # TOC1
  "AT2G25930",  # GI
  "AT2G18790",  # CCA1
  "AT3G46640",  # LUX
  "AT2G40080",  # ELF3
  "AT5G02810",  # PRR7
  "AT5G24470",  # PRR5
  "AT2G46790",  # PRR9
  "AT1G04400",  # CRY2
  "AT1G01060",  # LHY
  "AT4G08920",  # CRY1
  "AT2G40180"   # ELF4

)
circadian_data <- expr[
  expr$TAIR %in% circadian_genes,
]
gene_fc <- circadian_data$log2FC

names(gene_fc) <- circadian_data$TAIR
mapped_ids <- mapIds(
  org.At.tair.db,
  keys = names(gene_fc),
  column = "ENTREZID",
  keytype = "TAIR",
  multiVals = "first"
)
gene_data <- gene_fc

names(gene_data) <- mapped_ids

gene_data <- gene_data[
  !is.na(names(gene_data))
]
pathview(
  gene.data = gene_data,
  pathway.id = "ath04712",
  species = "ath",
  out.suffix = "GLDS612_Circadian"
)
